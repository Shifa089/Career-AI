# API Gateway base — Vite proxies /api and /oauth2 here (see vite.config.ts).
# The axios client uses the relative "/api/v1" prefix, so this is informational for dev.
VITE_API_BASE=http://localhost:8080

# Interview WebSocket (SockJS) endpoint. In dev this is proxied via Vite (/ws → 8083).
# Use a relative "/ws" so SockJS goes through the dev proxy; override for prod builds.
VITE_WS_URL=/ws
