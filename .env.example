# ---------------------------------------------------------------------------
# CareerAI environment variables. Copy to `.env` and fill in real values.
# ---------------------------------------------------------------------------

# --- Database ---
DB_USERNAME=careerai
DB_PASSWORD=change-me
DB_HOST=localhost

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# --- JWT ---
JWT_SECRET=replace-with-a-secure-random-string-at-least-256-bits-long
JWT_ACCESS_EXPIRY_MS=900000          # 15 minutes
JWT_REFRESH_EXPIRY_MS=604800000      # 7 days

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# --- OAuth2: Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OAuth2: GitHub ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- AWS S3 (LocalStack in dev) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET=careerai-resumes
AWS_S3_ENDPOINT=http://localhost:4566

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Mail (Mailpit/SMTP in dev) ---
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Tracing ---
ZIPKIN_BASE_URL=http://localhost:9411

# --- Application ---
APP_BASE_URL=http://localhost:8080

# --- Service discovery / config ---
EUREKA_URL=http://localhost:8761/eureka/
CONFIG_SERVER_URL=http://localhost:8888

# --- Grafana ---
GRAFANA_PASSWORD=admin
